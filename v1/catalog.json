{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kaltura.github.io/a2ui/v1/catalog.json",
  "title": "Kaltura Experience Components Catalog",
  "description": "A2UI catalog for Kaltura Experience Components — Player v7, Flashcards, Media Manager, and more. Freestanding schema with all types inlined. Extends the basic A2UI catalog with rich media components backed by the Kaltura platform.",
  "catalogId": "https://kaltura.github.io/a2ui/v1/catalog.json",
  "components": {
    "KalturaPlayer": {
      "type": "object",
      "description": "Kaltura Player v7 — full-featured video player with DRM, multi-audio, 30+ plugins, captions, analytics tracking, ad insertion, and cue points. Renders as an iframe.",
      "allOf": [
        { "$ref": "#/$defs/ComponentCommon" },
        { "$ref": "#/$defs/CatalogComponentCommon" },
        {
          "type": "object",
          "properties": {
            "component": { "const": "KalturaPlayer" },
            "partnerId": {
              "type": "integer",
              "description": "Kaltura account/partner ID."
            },
            "uiconfId": {
              "type": "integer",
              "description": "Player configuration ID (from KMC Studio or uiConf.list)."
            },
            "entryId": {
              "$ref": "#/$defs/DynamicString",
              "description": "Media entry ID to play."
            },
            "ks": {
              "$ref": "#/$defs/DynamicString",
              "description": "Kaltura Session token for access-controlled content. USER KS (type=0)."
            },
            "autoplay": {
              "$ref": "#/$defs/DynamicBoolean",
              "description": "Auto-start playback. Requires muted=true per browser policy. Default: false.",
              "default": false
            },
            "muted": {
              "$ref": "#/$defs/DynamicBoolean",
              "description": "Start muted. Must be true when autoplay is true. Default: false.",
              "default": false
            },
            "startTime": {
              "$ref": "#/$defs/DynamicNumber",
              "description": "Seek to this position (seconds) on load."
            },
            "clipTo": {
              "$ref": "#/$defs/DynamicNumber",
              "description": "Stop playback at this position (seconds)."
            },
            "aspectRatio": {
              "$ref": "#/$defs/DynamicString",
              "description": "Container aspect ratio (e.g. '16/9', '4/3'). Default: '16/9'.",
              "default": "16/9"
            }
          },
          "required": ["component", "partnerId", "uiconfId", "entryId"]
        }
      ],
      "unevaluatedProperties": false
    },
    "KalturaFlashcards": {
      "type": "object",
      "description": "Kaltura Flashcards — structured content cards with optional video clips for each card. Ideal for study material, topic summaries, and bite-sized learning derived from video content.",
      "allOf": [
        { "$ref": "#/$defs/ComponentCommon" },
        { "$ref": "#/$defs/CatalogComponentCommon" },
        {
          "type": "object",
          "properties": {
            "component": { "const": "KalturaFlashcards" },
            "title": {
              "$ref": "#/$defs/DynamicString",
              "description": "Title of the flashcard deck."
            },
            "summary": {
              "$ref": "#/$defs/DynamicString",
              "description": "Brief summary or description of the flashcard deck."
            },
            "cards": {
              "type": "array",
              "description": "Ordered list of flashcard items.",
              "items": {
                "type": "object",
                "properties": {
                  "title": {
                    "$ref": "#/$defs/DynamicString",
                    "description": "Card title (front of card)."
                  },
                  "subtitle": {
                    "$ref": "#/$defs/DynamicString",
                    "description": "Optional subtitle or category label."
                  },
                  "content": {
                    "$ref": "#/$defs/DynamicString",
                    "description": "Markdown body content (back of card)."
                  },
                  "clips": {
                    "type": "array",
                    "description": "Video clips relevant to this card.",
                    "items": {
                      "type": "object",
                      "properties": {
                        "entryId": {
                          "type": "string",
                          "description": "Kaltura media entry ID."
                        },
                        "startTime": {
                          "type": "number",
                          "description": "Clip start time in seconds."
                        },
                        "endTime": {
                          "type": "number",
                          "description": "Clip end time in seconds."
                        },
                        "title": {
                          "type": "string",
                          "description": "Optional clip title."
                        },
                        "thumbnail": {
                          "type": "string",
                          "description": "Optional thumbnail URL for the clip."
                        }
                      },
                      "required": ["entryId", "startTime", "endTime"],
                      "additionalProperties": false
                    }
                  }
                },
                "required": ["title", "content"],
                "additionalProperties": false
              }
            },
            "partnerId": {
              "type": "integer",
              "description": "Kaltura account/partner ID. Injected by the renderer."
            },
            "uiconfId": {
              "type": "integer",
              "description": "Player uiConf ID for flashcard clip playback. Auto-discovered if omitted; injected by the renderer."
            },
            "ks": {
              "$ref": "#/$defs/DynamicString",
              "description": "USER KS (type=0) for clip playback, scoped by the renderer."
            }
          },
          "required": ["component", "title", "cards"]
        }
      ],
      "unevaluatedProperties": false
    },
    "KalturaMediaManager": {
      "type": "object",
      "description": "Kaltura Media Manager — browsable content library for selecting, previewing, and managing media entries. Supports category-scoped views, selection mode for embedding, and full management mode for content operations.",
      "allOf": [
        { "$ref": "#/$defs/ComponentCommon" },
        { "$ref": "#/$defs/CatalogComponentCommon" },
        {
          "type": "object",
          "properties": {
            "component": { "const": "KalturaMediaManager" },
            "partnerId": {
              "type": "integer",
              "description": "Kaltura account/partner ID."
            },
            "ks": {
              "$ref": "#/$defs/DynamicString",
              "description": "USER KS (type=0). Scoped by the renderer for the session user."
            },
            "serverUrl": {
              "$ref": "#/$defs/DynamicString",
              "description": "Kaltura Unisphere CDN base URL for this partner's region (e.g. 'https://unisphere.nvp1.ovp.kaltura.com/v1')."
            },
            "theme": {
              "type": "string",
              "enum": ["dark", "light"],
              "description": "UI theme mode. Default: follows system preference.",
              "default": "light"
            },
            "mode": {
              "type": "string",
              "enum": ["select", "manage"],
              "description": "Interaction mode. 'select' for content picking, 'manage' for full CRUD operations.",
              "default": "manage"
            },
            "contextType": {
              "type": "string",
              "description": "Type of content scope. Default: 'category'.",
              "default": "category"
            },
            "contextId": {
              "$ref": "#/$defs/DynamicString",
              "description": "ID of the content scope (e.g. category ID to browse)."
            }
          },
          "required": ["component", "partnerId", "ks", "serverUrl"]
        }
      ],
      "unevaluatedProperties": false
    },
    "KalturaChart": {
      "type": "object",
      "description": "Interactive data chart rendered via visx. Supports line, bar, area, pie, scatter, geo, wordcloud, treemap, heatmap, radar, sankey, and funnel chart types.",
      "allOf": [
        { "$ref": "#/$defs/ComponentCommon" },
        { "$ref": "#/$defs/CatalogComponentCommon" },
        {
          "type": "object",
          "properties": {
            "component": { "const": "KalturaChart" },
            "chartType": {
              "type": "string",
              "enum": ["line", "bar", "area", "pie", "scatter", "geo", "wordcloud", "treemap", "heatmap", "radar", "sankey", "funnel"],
              "description": "Visualization type."
            },
            "data": {
              "type": "array",
              "description": "Array of data point objects. Keys become axis labels and series names.",
              "items": { "type": "object" }
            },
            "title": {
              "$ref": "#/$defs/DynamicString",
              "description": "Chart title displayed above the visualization."
            },
            "xKey": {
              "$ref": "#/$defs/DynamicString",
              "description": "Data field to use as the x-axis / category key. Auto-detected if omitted."
            },
            "yKeys": {
              "type": "array",
              "items": { "type": "string" },
              "description": "Data fields to plot as y-axis series. Auto-detected if omitted."
            },
            "yLabels": {
              "type": "array",
              "items": { "type": "string" },
              "description": "Human-readable labels for each yKey series (legend labels)."
            },
            "xLabel": {
              "$ref": "#/$defs/DynamicString",
              "description": "X-axis label."
            },
            "yLabel": {
              "$ref": "#/$defs/DynamicString",
              "description": "Y-axis label."
            },
            "colors": {
              "type": "array",
              "items": { "type": "string" },
              "description": "Override series colors (CSS color strings, cycled)."
            },
            "height": {
              "$ref": "#/$defs/DynamicNumber",
              "description": "Chart height in pixels. Default: 300.",
              "default": 300
            },
            "annotations": {
              "type": "array",
              "description": "Vertical annotation lines on cartesian charts.",
              "items": {
                "type": "object",
                "properties": {
                  "x": { "type": "string", "description": "x-axis value where the annotation line is drawn." },
                  "label": { "type": "string", "description": "Label text shown on the annotation." },
                  "color": { "type": "string", "description": "Line color (CSS color string). Default: accent color." }
                },
                "required": ["x", "label"],
                "additionalProperties": false
              }
            }
          },
          "required": ["component", "chartType", "data"]
        }
      ],
      "unevaluatedProperties": false
    },
    "KalturaAnalytics": {
      "type": "object",
      "description": "Kaltura Analytics — KMC analytics dashboard for entry or account-level metrics. Renders as an iframe.",
      "allOf": [
        { "$ref": "#/$defs/ComponentCommon" },
        { "$ref": "#/$defs/CatalogComponentCommon" },
        {
          "type": "object",
          "properties": {
            "component": { "const": "KalturaAnalytics" },
            "partnerId": {
              "type": "integer",
              "description": "Kaltura account/partner ID."
            },
            "ks": {
              "$ref": "#/$defs/DynamicString",
              "description": "Kaltura Session token. ADMIN KS (type=2) required for analytics access."
            },
            "entryId": {
              "$ref": "#/$defs/DynamicString",
              "description": "Media entry ID for entry-level analytics. Omit for account-level reporting."
            },
            "reportType": {
              "type": "string",
              "description": "Analytics report type ID (e.g. '1' for top content). Omit to use the default dashboard."
            },
            "fromDate": {
              "$ref": "#/$defs/DynamicString",
              "description": "Report start date in ISO 8601 format (e.g. '2024-01-01')."
            },
            "toDate": {
              "$ref": "#/$defs/DynamicString",
              "description": "Report end date in ISO 8601 format (e.g. '2024-12-31')."
            }
          },
          "required": ["component", "partnerId", "ks"]
        }
      ],
      "unevaluatedProperties": false
    },
    "KalturaCaptionsEditor": {
      "type": "object",
      "description": "Kaltura Captions Editor — inline subtitle editing interface for correcting and timing captions. Renders as an iframe.",
      "allOf": [
        { "$ref": "#/$defs/ComponentCommon" },
        { "$ref": "#/$defs/CatalogComponentCommon" },
        {
          "type": "object",
          "properties": {
            "component": { "const": "KalturaCaptionsEditor" },
            "partnerId": {
              "type": "integer",
              "description": "Kaltura account/partner ID."
            },
            "ks": {
              "$ref": "#/$defs/DynamicString",
              "description": "Kaltura Session token. USER KS (type=0) with sview privilege for the entry."
            },
            "entryId": {
              "$ref": "#/$defs/DynamicString",
              "description": "Media entry ID whose captions will be edited."
            },
            "uiconfId": {
              "type": "integer",
              "description": "Player uiConf ID used by the captions editor preview. Auto-discovered from account defaults if omitted."
            }
          },
          "required": ["component", "partnerId", "ks", "entryId"]
        }
      ],
      "unevaluatedProperties": false
    },
    "KalturaRecorder": {
      "type": "object",
      "description": "Kaltura Express Recorder — browser-based screen/webcam capture widget injected via JavaScript. Requires USER KS with recording privileges.",
      "allOf": [
        { "$ref": "#/$defs/ComponentCommon" },
        { "$ref": "#/$defs/CatalogComponentCommon" },
        {
          "type": "object",
          "properties": {
            "component": { "const": "KalturaRecorder" },
            "partnerId": {
              "type": "integer",
              "description": "Kaltura account/partner ID."
            },
            "ks": {
              "$ref": "#/$defs/DynamicString",
              "description": "Kaltura Session token. USER KS (type=0) with recording privileges."
            },
            "uiconfId": {
              "type": "integer",
              "description": "Recorder uiConf ID. Auto-discovered from account defaults if omitted."
            },
            "category": {
              "$ref": "#/$defs/DynamicString",
              "description": "Category name or ID to save the recorded entry into."
            },
            "entryName": {
              "$ref": "#/$defs/DynamicString",
              "description": "Default name for the newly recorded entry."
            },
            "allowScreen": {
              "$ref": "#/$defs/DynamicBoolean",
              "description": "Allow screen capture mode. Default: true.",
              "default": true
            },
            "allowCamera": {
              "$ref": "#/$defs/DynamicBoolean",
              "description": "Allow webcam/camera capture mode. Default: true.",
              "default": true
            }
          },
          "required": ["component", "partnerId", "ks"]
        }
      ],
      "unevaluatedProperties": false
    },
    "KalturaAvatar": {
      "type": "object",
      "description": "Kaltura AI Avatar — conversational avatar widget powered by avatar.us.kaltura.ai. Injects via JavaScript SDK. No Kaltura KS required; uses external avatar auth.",
      "allOf": [
        { "$ref": "#/$defs/ComponentCommon" },
        { "$ref": "#/$defs/CatalogComponentCommon" },
        {
          "type": "object",
          "properties": {
            "component": { "const": "KalturaAvatar" },
            "avatarId": {
              "$ref": "#/$defs/DynamicString",
              "description": "Unique avatar configuration ID from the Kaltura Avatar service."
            },
            "projectId": {
              "$ref": "#/$defs/DynamicString",
              "description": "Avatar project ID for multi-project accounts."
            },
            "language": {
              "type": "string",
              "description": "BCP 47 language code for the avatar interaction. Default: 'en'.",
              "default": "en"
            },
            "autoStart": {
              "$ref": "#/$defs/DynamicBoolean",
              "description": "Automatically start the avatar session on load. Default: false.",
              "default": false
            },
            "allowInterrupt": {
              "$ref": "#/$defs/DynamicBoolean",
              "description": "Allow the user to interrupt the avatar while it is speaking. Default: true.",
              "default": true
            }
          },
          "required": ["component", "avatarId"]
        }
      ],
      "unevaluatedProperties": false
    },
    "KalturaGenie": {
      "type": "object",
      "description": "Kaltura Genie — AI-powered video discovery and Q&A widget. Delivers conversational search and smart video recommendations via Unisphere.",
      "allOf": [
        { "$ref": "#/$defs/ComponentCommon" },
        { "$ref": "#/$defs/CatalogComponentCommon" },
        {
          "type": "object",
          "properties": {
            "component": { "const": "KalturaGenie" },
            "partnerId": {
              "type": "integer",
              "description": "Kaltura account/partner ID."
            },
            "ks": {
              "$ref": "#/$defs/DynamicString",
              "description": "Kaltura Session token. USER KS (type=0) scoped to the discoverable content."
            },
            "serverUrl": {
              "$ref": "#/$defs/DynamicString",
              "description": "Kaltura Unisphere CDN base URL for this partner's region (e.g. 'https://unisphere.nvp1.ovp.kaltura.com/v1')."
            },
            "categoryId": {
              "$ref": "#/$defs/DynamicString",
              "description": "Category ID to scope discovery. Omit for account-wide search."
            },
            "language": {
              "type": "string",
              "description": "BCP 47 language code for the Genie interface. Default: 'en'.",
              "default": "en"
            }
          },
          "required": ["component", "partnerId", "ks", "serverUrl"]
        }
      ],
      "unevaluatedProperties": false
    },
    "KalturaContentLab": {
      "type": "object",
      "description": "Kaltura Content Lab — AI-powered content creation and enrichment studio. Generates clips, chapters, captions, and quizzes from existing media. Requires ADMIN KS. Renders via Unisphere.",
      "allOf": [
        { "$ref": "#/$defs/ComponentCommon" },
        { "$ref": "#/$defs/CatalogComponentCommon" },
        {
          "type": "object",
          "properties": {
            "component": { "const": "KalturaContentLab" },
            "partnerId": {
              "type": "integer",
              "description": "Kaltura account/partner ID."
            },
            "ks": {
              "$ref": "#/$defs/DynamicString",
              "description": "Kaltura Session token. ADMIN KS (type=2) required for enrichment operations."
            },
            "serverUrl": {
              "$ref": "#/$defs/DynamicString",
              "description": "Kaltura Unisphere CDN base URL for this partner's region (e.g. 'https://unisphere.nvp1.ovp.kaltura.com/v1')."
            },
            "entryId": {
              "$ref": "#/$defs/DynamicString",
              "description": "Media entry ID to pre-select in the Content Lab. Omit to open the full library view."
            }
          },
          "required": ["component", "partnerId", "ks", "serverUrl"]
        }
      ],
      "unevaluatedProperties": false
    },
    "KalturaAgentsWidget": {
      "type": "object",
      "description": "Kaltura AI Agents Widget — operator dashboard for configuring and managing AI agents attached to media workflows. Requires ADMIN KS. Renders via Unisphere.",
      "allOf": [
        { "$ref": "#/$defs/ComponentCommon" },
        { "$ref": "#/$defs/CatalogComponentCommon" },
        {
          "type": "object",
          "properties": {
            "component": { "const": "KalturaAgentsWidget" },
            "partnerId": {
              "type": "integer",
              "description": "Kaltura account/partner ID."
            },
            "ks": {
              "$ref": "#/$defs/DynamicString",
              "description": "Kaltura Session token. ADMIN KS (type=2) required for agent management."
            },
            "serverUrl": {
              "$ref": "#/$defs/DynamicString",
              "description": "Kaltura Unisphere CDN base URL for this partner's region (e.g. 'https://unisphere.nvp1.ovp.kaltura.com/v1')."
            },
            "agentId": {
              "$ref": "#/$defs/DynamicString",
              "description": "Agent configuration ID to pre-select in the dashboard. Omit to open the full agent list."
            }
          },
          "required": ["component", "partnerId", "ks", "serverUrl"]
        }
      ],
      "unevaluatedProperties": false
    },
    "KalturaVodAvatar": {
      "type": "object",
      "description": "Kaltura VOD Avatar — renders a pre-recorded AI avatar presentation for a video entry. The avatar reads scripted content synchronized with media. Renders via Unisphere.",
      "allOf": [
        { "$ref": "#/$defs/ComponentCommon" },
        { "$ref": "#/$defs/CatalogComponentCommon" },
        {
          "type": "object",
          "properties": {
            "component": { "const": "KalturaVodAvatar" },
            "partnerId": {
              "type": "integer",
              "description": "Kaltura account/partner ID."
            },
            "ks": {
              "$ref": "#/$defs/DynamicString",
              "description": "Kaltura Session token. USER KS (type=0) with playback access to the entry."
            },
            "serverUrl": {
              "$ref": "#/$defs/DynamicString",
              "description": "Kaltura Unisphere CDN base URL for this partner's region (e.g. 'https://unisphere.nvp1.ovp.kaltura.com/v1')."
            },
            "entryId": {
              "$ref": "#/$defs/DynamicString",
              "description": "Media entry ID whose content the avatar presents synchronized."
            },
            "avatarStyle": {
              "type": "string",
              "description": "Visual style preset for the avatar (e.g. 'professional', 'casual'). Uses account default if omitted."
            }
          },
          "required": ["component", "partnerId", "ks", "serverUrl", "entryId"]
        }
      ],
      "unevaluatedProperties": false
    }
  },
  "$defs": {
    "DataBinding": {
      "type": "object",
      "description": "A reference to a value in the data model via JSON Pointer path.",
      "properties": {
        "path": {
          "type": "string",
          "description": "A JSON Pointer path to a value in the data model."
        }
      },
      "required": ["path"],
      "additionalProperties": false
    },
    "DynamicString": {
      "description": "A string value — either a literal string or a data-binding reference.",
      "oneOf": [
        { "type": "string" },
        { "$ref": "#/$defs/DataBinding" }
      ]
    },
    "DynamicNumber": {
      "description": "A numeric value — either a literal number or a data-binding reference.",
      "oneOf": [
        { "type": "number" },
        { "$ref": "#/$defs/DataBinding" }
      ]
    },
    "DynamicBoolean": {
      "description": "A boolean value — either a literal boolean or a data-binding reference.",
      "oneOf": [
        { "type": "boolean" },
        { "$ref": "#/$defs/DataBinding" }
      ]
    },
    "ComponentId": {
      "type": "string",
      "description": "Unique identifier for a component instance within a surface."
    },
    "AccessibilityAttributes": {
      "type": "object",
      "description": "Attributes for assistive technologies (screen readers, etc.).",
      "properties": {
        "label": {
          "$ref": "#/$defs/DynamicString",
          "description": "Short accessible label (1-3 words) conveying element purpose."
        },
        "description": {
          "$ref": "#/$defs/DynamicString",
          "description": "Additional context provided by assistive technologies."
        }
      },
      "additionalProperties": false
    },
    "ComponentCommon": {
      "type": "object",
      "description": "Base properties shared by all components (from A2UI spec).",
      "properties": {
        "id": {
          "$ref": "#/$defs/ComponentId"
        },
        "accessibility": {
          "$ref": "#/$defs/AccessibilityAttributes"
        }
      },
      "required": ["id"]
    },
    "CatalogComponentCommon": {
      "type": "object",
      "description": "Catalog-level properties shared by all Kaltura components.",
      "properties": {
        "tooltip": {
          "$ref": "#/$defs/DynamicString",
          "description": "Tooltip text shown on hover."
        },
        "visible": {
          "$ref": "#/$defs/DynamicBoolean",
          "description": "Controls component visibility.",
          "default": true
        }
      }
    },
    "anyComponent": {
      "oneOf": [
        { "$ref": "#/components/KalturaPlayer" },
        { "$ref": "#/components/KalturaFlashcards" },
        { "$ref": "#/components/KalturaMediaManager" },
        { "$ref": "#/components/KalturaChart" },
        { "$ref": "#/components/KalturaAnalytics" },
        { "$ref": "#/components/KalturaCaptionsEditor" },
        { "$ref": "#/components/KalturaRecorder" },
        { "$ref": "#/components/KalturaAvatar" },
        { "$ref": "#/components/KalturaGenie" },
        { "$ref": "#/components/KalturaContentLab" },
        { "$ref": "#/components/KalturaAgentsWidget" },
        { "$ref": "#/components/KalturaVodAvatar" }
      ]
    },
    "theme": {
      "type": "object",
      "description": "Full theme object for Kaltura surfaces. Includes palette, typography, shape tokens, and flashcard gradients so any A2UI renderer can apply consistent Kaltura branding.",
      "properties": {
        "primaryColor": {
          "type": "string",
          "description": "Primary brand color (hex). Default: Kaltura Stream Blue #006EFA."
        },
        "mode": {
          "type": "string",
          "enum": ["light", "dark"],
          "description": "Light or dark theme mode.",
          "default": "dark"
        },
        "palette": {
          "type": "object",
          "description": "Color palette tokens resolved per theme mode.",
          "properties": {
            "primary": {
              "type": "object",
              "properties": {
                "main": { "type": "string", "description": "Primary interactive color (hex)." },
                "contrastText": { "type": "string", "description": "Text color on primary surfaces (hex)." }
              },
              "required": ["main"],
              "additionalProperties": false
            },
            "secondary": {
              "type": "object",
              "properties": {
                "main": { "type": "string", "description": "Secondary accent color (hex)." }
              },
              "required": ["main"],
              "additionalProperties": false
            },
            "danger": {
              "type": "object",
              "properties": {
